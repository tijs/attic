{
  "workspace": ["./shared", "./cli"],
  "tasks": {
    "check": "deno check cli/mod.ts",
    "test": "deno test --allow-read --allow-write --allow-env --allow-ffi --allow-net",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "scan": "deno run --allow-read --allow-env=HOME --allow-ffi cli/mod.ts scan",
    "status": "deno run --allow-read --allow-write --allow-env=HOME --allow-ffi cli/mod.ts status",
    "backup": "deno run --allow-read --allow-write --allow-env=HOME --allow-ffi --allow-net=s3.fr-par.scw.cloud --allow-run=security,ladder cli/mod.ts backup",
    "verify": "deno run --allow-read --allow-write --allow-env=HOME --allow-net=s3.fr-par.scw.cloud --allow-run=security cli/mod.ts verify"
  }
}
